# Copy to .env and fill in the keys for the providers you use.

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Zhipu GLM — https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=

# Anthropic Claude (via OpenAI-compat layer) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: default provider on startup (deepseek | glm | claude)
NEUTRIX_PROVIDER=deepseek

# Optional: override default model for a provider
# NEUTRIX_MODEL=deepseek-chat
